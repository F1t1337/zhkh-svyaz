  <!-- ==================== UC-07: Рассылка уведомлений ==================== -->
  <diagram name="UC-07 Рассылка уведомлений" id="act-uc07">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="t" value="Диаграмма деятельности — UC-07: Рассылка уведомлений жильцам (то же что UC-02 со стороны админа)" style="text;html=1;fontSize=15;fontStyle=1;fillColor=none;strokeColor=none;align=center" vertex="1" parent="1"><mxGeometry x="50" y="10" width="1100" height="30" as="geometry" /></mxCell>
        <!-- Эта диаграмма по сути повторяет UC-02 (тот же процесс глазами админа), см. вкладку UC-02 -->
        <mxCell id="note" value="Данная диаграмма идентична UC-02 «Получение уведомления», описывающей тот же процесс.&#xa;Основной поток — со стороны администратора:&#xa;&#xa;1. Перейти в раздел «Уведомления» → «Создать»&#xa;2. Ввести текст уведомления&#xa;3. Выбрать получателей (все жильцы / конкретные квартиры)&#xa;4. Подтвердить отправку&#xa;5. [Развилка] Текст заполнен? → нет: ошибка, вернуться к шагу 2&#xa;6. Система рассылает push-уведомления&#xa;7. Уведомление сохраняется в истории рассылок&#xa;&#xa;Альтернативный поток: текст не заполнен — система блокирует отправку.&#xa;&#xa;См. полную диаграмму на вкладке «UC-02 Получение уведомления»" style="text;html=1;fontSize=13;align=left;verticalAlign=top;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#999;rounded=1;spacingLeft=10;spacingTop=10;spacingRight=10" vertex="1" parent="1"><mxGeometry x="100" y="80" width="1000" height="300" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

