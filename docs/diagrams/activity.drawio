  <!-- ==================== UC-01: Просмотр сводки начислений ==================== -->
  <diagram name="UC-01 Просмотр сводки начислений" id="act-uc01">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="t" value="Диаграмма деятельности — UC-01: Просмотр сводки начислений" style="text;html=1;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;align=center" vertex="1" parent="1"><mxGeometry x="100" y="10" width="1000" height="30" as="geometry" /></mxCell>

        <!-- Swimlanes -->
        <mxCell id="pool" value="" style="shape=swimlane;startSize=0;horizontal=0;fillColor=#f5f5f5;strokeColor=#666;collapsible=0" vertex="1" parent="1"><mxGeometry x="40" y="60" width="1120" height="800" as="geometry" /></mxCell>
        <mxCell id="lane_sys" value="Система" style="shape=swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;swimlaneFillColor=#ffffff;fontSize=13;fontStyle=1" vertex="1" parent="pool"><mxGeometry x="0" y="0" width="370" height="800" as="geometry" /></mxCell>
        <mxCell id="lane_zh" value="Жилец" style="shape=swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;swimlaneFillColor=#ffffff;fontSize=13;fontStyle=1" vertex="1" parent="pool"><mxGeometry x="370" y="0" width="400" height="800" as="geometry" /></mxCell>
        <mxCell id="lane_ad" value="Администратор" style="shape=swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;swimlaneFillColor=#ffffff;fontSize=13;fontStyle=1" vertex="1" parent="pool"><mxGeometry x="770" y="0" width="350" height="800" as="geometry" /></mxCell>

        <!-- Начало -->
        <mxCell id="s" value="" style="ellipse;fillColor=#000;strokeColor=#000" vertex="1" parent="1"><mxGeometry x="190" y="110" width="30" height="30" as="geometry" /></mxCell>
        <!-- Формирование сводки -->
        <mxCell id="a1" value="Расчётный период завершён.&#xa;Автоматически сформировать&#xa;сводку начислений" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12" vertex="1" parent="1"><mxGeometry x="100" y="170" width="220" height="70" as="geometry" /></mxCell>
        <!-- Отправить push -->
        <mxCell id="a2" value="Отправить push-уведомление&#xa;жильцу о новой сводке" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12" vertex="1" parent="1"><mxGeometry x="100" y="280" width="220" height="60" as="geometry" /></mxCell>
        <!-- Развилка: push доставлен? -->
        <mxCell id="d1" value="Push&#xa;доставлен?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1"><mxGeometry x="510" y="270" width="120" height="80" as="geometry" /></mxCell>
        <!-- Жилец получает push -->
        <mxCell id="a3" value="Получить push-уведомление" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="1"><mxGeometry x="480" y="390" width="200" height="50" as="geometry" /></mxCell>
        <!-- Жилец при следующем входе -->
        <mxCell id="a3b" value="При следующем входе&#xa;увидеть сводку в разделе&#xa;«Начисления»" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="1"><mxGeometry x="680" y="270" width="200" height="70" as="geometry" /></mxCell>
        <!-- Открыть раздел -->
        <mxCell id="a4" value="Открыть раздел «Начисления»" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="1"><mxGeometry x="480" y="480" width="200" height="50" as="geometry" /></mxCell>
        <!-- Просмотр детализации -->
        <mxCell id="a5" value="Просмотреть детализацию&#xa;(ХВС, ГВС, электроэнергия,&#xa;газ, вывоз мусора и др.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="1"><mxGeometry x="480" y="570" width="220" height="70" as="geometry" /></mxCell>
        <!-- Система фиксирует просмотр -->
        <mxCell id="a6" value="Зафиксировать факт&#xa;просмотра сводки" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12" vertex="1" parent="1"><mxGeometry x="100" y="580" width="220" height="50" as="geometry" /></mxCell>
        <!-- Администратор видит статистику -->
        <mxCell id="a7" value="Просмотреть статистику&#xa;осведомлённости жильцов" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12" vertex="1" parent="1"><mxGeometry x="870" y="580" width="220" height="50" as="geometry" /></mxCell>
        <!-- Конец -->
        <mxCell id="e" value="" style="ellipse;fillColor=#fff;strokeColor=#000;strokeWidth=3" vertex="1" parent="1"><mxGeometry x="572" y="710" width="36" height="36" as="geometry" /></mxCell>
        <mxCell id="ei" value="" style="ellipse;fillColor=#000;strokeColor=#000" vertex="1" parent="1"><mxGeometry x="580" y="718" width="20" height="20" as="geometry" /></mxCell>

        <!-- Связи -->
        <mxCell id="f1" style="endArrow=classic;html=1" edge="1" parent="1" source="s" target="a1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f2" style="endArrow=classic;html=1" edge="1" parent="1" source="a1" target="a2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f3" style="endArrow=classic;html=1" edge="1" parent="1" source="a2" target="d1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f4" value="да" style="endArrow=classic;html=1;fontSize=11" edge="1" parent="1" source="d1" target="a3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f5" value="нет" style="endArrow=classic;html=1;fontSize=11" edge="1" parent="1" source="d1" target="a3b"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f6" style="endArrow=classic;html=1" edge="1" parent="1" source="a3" target="a4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f6b" style="endArrow=classic;html=1" edge="1" parent="1" source="a3b" target="a4"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="780" y="505" /></Array></mxGeometry></mxCell>
        <mxCell id="f7" style="endArrow=classic;html=1" edge="1" parent="1" source="a4" target="a5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f8" style="endArrow=classic;html=1" edge="1" parent="1" source="a5" target="a6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f9" style="endArrow=classic;html=1;dashed=1" edge="1" parent="1" source="a6" target="a7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f10" style="endArrow=classic;html=1" edge="1" parent="1" source="a5" target="e"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
